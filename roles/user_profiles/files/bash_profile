# Float calculator, usage examples:
# c 2 / 2
# c 2 * 2
# c "(2 + 2) * 2"
alias c="set -f; bc_wrap"
bc_wrap() {
    echo "scale=16; $@" | bc | perl -ne 'printf "%.8f", $_;'
    set +f
}

# Search in bash history, usage:
# hh <search string>
hh() {
    history | grep -i "$@"
}
HISTIGNORE='hh *:ll:bg:fg:exit'

