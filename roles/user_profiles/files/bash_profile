# Show accurate per-process memory usage (PSS/USS)
alias mem='echo; for pid in $(ps -e -o pid=); do f=/proc/$pid/smaps_rollup; [ -r "$f" ] || continue; cmd=$(tr "\0" " " </proc/$pid/cmdline | cut -c1-80); [ -z "$cmd" ] && cmd=$(ps -p $pid -o comm=); awk -v pid="$pid" -v cmd="$cmd" '"'"'BEGIN{pss=0;pc=0;pd=0} /^Pss:/ {pss=$2} /^Private_Clean:/ {pc=$2} /^Private_Dirty:/ {pd=$2} END { if (pss>0 && pid ~ /^[0-9]+$/) printf "%d\t%s\t%d\t%s\n", pss, pid, pc+pd, cmd }'"'"' "$f" 2>/dev/null; done | sort -n | awk -F "\t" '"'"'BEGIN {print "--------------------------------------------------------------------------------"; printf "%-8s | %-12s | %-12s | %s\n", "PID", "PSS (MB)", "USS (MB)", "COMMAND"; print "--------------------------------------------------------------------------------"; tp=0; tu=0} $2 ~ /^[0-9]+$/ {tp+=$1; tu+=$3; printf "%-8s | %12.2f | %12.2f | %s\n", $2, $1/1024, $3/1024, $4} END {print "--------------------------------------------------------------------------------"; printf "%-8s | %12.2f | %12.2f | %s\n", "TOTAL", tp/1024, tu/1024, ""}'"'"''

# Show accurate per-process memory usage (PSS/USS) - with users
alias memu='echo; for pid in $(ps -e -o pid=); do f=/proc/$pid/smaps_rollup; [ -r "$f" ] || continue; user=$(ps -p $pid -o user= | tr -d " "); cmd=$(tr "\0" " " </proc/$pid/cmdline | cut -c1-80); [ -z "$cmd" ] && cmd=$(ps -p $pid -o comm=); awk -v pid="$pid" -v user="$user" -v cmd="$cmd" '"'"'BEGIN{pss=0;pc=0;pd=0} /^Pss:/ {pss=$2} /^Private_Clean:/ {pc=$2} /^Private_Dirty:/ {pd=$2} END { if (pss>0 && pid ~ /^[0-9]+$/) printf "%d\t%s\t%s\t%d\t%s\n", pss, pid, user, pc+pd, cmd }'"'"' "$f" 2>/dev/null; done | sort -n | awk -F "\t" '"'"'BEGIN {print "----------------------------------------------------------------------------------------------------"; printf "%-8s | %-12s | %-12s | %-12s | %s\n", "PID", "USER", "PSS (MB)", "USS (MB)", "COMMAND"; print "----------------------------------------------------------------------------------------------------"; tp=0; tu=0} $2 ~ /^[0-9]+$/ {tp+=$1; tu+=$4; printf "%-8s | %-12s | %12.2f | %12.2f | %s\n", $2, $3, $1/1024, $4/1024, $5} END {print "----------------------------------------------------------------------------------------------------"; printf "%-8s | %-12s | %12.2f | %12.2f | %s\n", "TOTAL", "", tp/1024, tu/1024, ""}'"'"''

